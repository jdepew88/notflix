# Server
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# Public URL (used for absolute links; set to your Traefik domain in production)
NEXT_PUBLIC_APP_URL=http://172.16.0.10:3233

# Persistent settings (merged with .env on startup)
DATA_PATH=/app/data

# Plex — use the IP:port your Docker container can reach (172.16.x.x LAN is fine)
# Find it in Plex → Settings → Network → Custom server access URLs, or your unRAID IP
PLEX_URL=http://172.16.0.10:32400
PLEX_TOKEN=

# NFS library mount inside the container (host /mnt/user/Media/Video → /media/Video)
LIBRARY_PATH=/media/Video

# Session cookies — set false for HTTP LAN access (e.g. http://172.16.0.10:3233)
COOKIE_SECURE=false
SESSION_SECRET=change-me-to-a-random-string

# Optional metadata APIs
TMDB_API_KEY=
TVDB_API_KEY=

# Optional Real-Debrid (enables Torrentio fallback when title is not in Plex)
REAL_DEBRID_TOKEN=

# Torrentio — English-only releases. If unset, auto-built from REAL_DEBRID_TOKEN with language=english.
# Paste from https://torrentio.strem.fun/configure (Copy Link → remove /manifest.json).
# language=english is required; the app appends it automatically if you forget.
# TORRENTIO_URL=https://torrentio.strem.fun/realdebrid=YOUR_TOKEN|sort=quality|language=english
# Note: qualityfilter EXCLUDES qualities — do not list cam/scr/ts if you want those sources.

# Optional Peerflix — include language=english (auto-appended if missing)
# PEERFLIX_URL=https://peerflix.mov/realdebrid=YOUR_TOKEN|language=english

# Prefer direct play — no server transcoding when the browser supports the codecs (H.264 + AAC).
DIRECT_PLAY=true

# Plex library only — hides TMDB browse rows, Debrid fallback, and streaming-service chips.
# Default is off (Plex + TMDB + Real-Debrid). Set true for a Plex-only home theater.
# PLEX_ONLY=true

# CPU-only servers: disable hero marquee ffmpeg (uses backdrop photo only — saves a lot of CPU).
HERO_VIDEO=false

# Optional: override ffmpeg paths (installed in container by default via apk)
# FFMPEG_PATH=/usr/bin/ffmpeg
# FFPROBE_PATH=/usr/bin/ffprobe

# CPU transcode tuning (only used when direct play is impossible — XviD, AC3, etc.)
# No GPU / Quick Sync / NVENC — software libx264 only.
# FFMPEG_PRESET=ultrafast
# FFMPEG_THREADS=2
# FFMPEG_TUNE=fastdecode

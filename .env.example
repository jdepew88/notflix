# Server
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# Public URL (used for absolute links; set to your Traefik domain in production)
NEXT_PUBLIC_APP_URL=http://10.10.0.8:3233

# Plex (required for library playback)
PLEX_URL=http://10.10.0.8:32800
PLEX_TOKEN=

# NFS library mount inside the container (read-only at /media)
LIBRARY_PATH=/media

# Optional metadata APIs
TMDB_API_KEY=
TVDB_API_KEY=

# Optional Real-Debrid (enables Torrentio fallback when title is not in Plex)
REAL_DEBRID_TOKEN=

# Optional: paste your full Torrentio install URL from https://torrentio.strem.fun/configure
# (Copy Link on Install — remove /manifest.json). If unset, built from REAL_DEBRID_TOKEN.
# TORRENTIO_URL=https://torrentio.strem.fun/realdebrid=YOUR_TOKEN|sort=quality|qualityfilter=480p,scr,cam,unknown

# Optional: override ffmpeg paths (installed in container by default)
# FFMPEG_PATH=/usr/bin/ffmpeg
# FFPROBE_PATH=/usr/bin/ffprobe
